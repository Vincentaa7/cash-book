# TiDB Cloud / MySQL Connection
# Ganti dengan kredensial TiDB Cloud Anda
TIDB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your_username.root
TIDB_PASSWORD=your_password
TIDB_DATABASE=cash_book

# Format Connection String untuk Prisma (Wajib SSL/TLS untuk TiDB Cloud public endpoint)
DATABASE_URL="mysql://${TIDB_USER}:${TIDB_PASSWORD}@${TIDB_HOST}:${TIDB_PORT}/${TIDB_DATABASE}?sslaccept=strict"

# Atau bisa juga ditulis langsung:
# DATABASE_URL="mysql://your_username.root:your_password@gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000/cash_book?sslaccept=strict"

# Secret untuk session/JWT (Ganti dengan string acak minimal 32 karakter di production)
JWT_SECRET="cash-book-super-secret-key-change-me"
